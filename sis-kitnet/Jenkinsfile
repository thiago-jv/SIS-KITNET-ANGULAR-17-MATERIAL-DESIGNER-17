pipeline {
    agent any

    options {
        timestamps()
        buildDiscarder(logRotator(numToKeepStr: '10'))
    }

    environment {
        IMAGE_NAME = 'kitnet-frontend'
        SONAR_QUBE_URL = 'http://localhost:9000'
        DSONAR_LOGIN = credentials('DSONAR_LOGIN_SIS_KITNET_FRONTEND')
    }

    stages {

        stage('Checkout') {
            steps {
                checkout scm
            }
        }

        stage('Build Frontend (Node via Docker)') {
            steps {
                sh '''
                                PROJECT_DIR="."
                                if [ -f "sis-kitnet/package-lock.json" ]; then
                                    PROJECT_DIR="sis-kitnet"
                                fi

                docker run --rm \
                  --user "$(id -u):$(id -g)" \
                                    -e HOME=/tmp \
                                    -e npm_config_cache=/tmp/.npm \
                  -v $PWD:/app \
                                    -w /app/$PROJECT_DIR \
                  node:18 \
                  sh -c "npm ci && npm run build -- --configuration production"
                '''
            }
        }

        stage('SonarQube Analysis') {
            steps {
                withSonarQubeEnv('SONAR_LOCAL') {
                    script {
                        def scannerHome = tool 'SONAR_SCANNER'
                        sh """
                                                PROJECT_DIR="."
                                                if [ -d "sis-kitnet/src" ]; then
                                                    PROJECT_DIR="sis-kitnet"
                                                fi

                                                cd "\$PROJECT_DIR"

                        ${scannerHome}/bin/sonar-scanner \\
                        -Dsonar.projectKey=SIS_KITNET_FRONTEND \\
                        -Dsonar.projectName=SIS_KITNET_FRONTEND \\
                        -Dsonar.host.url=${env.SONAR_QUBE_URL} \\
                        -Dsonar.token=${env.DSONAR_LOGIN} \\
                        -Dsonar.sources=src \\
                        -Dsonar.tests=src \\
                        -Dsonar.test.inclusions=**/*.spec.ts \\
                        -Dsonar.exclusions=**/node_modules/**,**/*.spec.ts,**/dist/** \\
                        -Dsonar.typescript.tsconfigPath=tsconfig.json
                        """
                    }
                }
            }
        }

        stage('Quality Gate') {
            steps {
                sleep(3)
                timeout(time: 3, unit: 'MINUTES') {
                    waitForQualityGate abortPipeline: true
                }
            }
        }

        stage('Docker Build') {
            steps {
                sh '''
                                PROJECT_DIR="."
                                if [ -f "sis-kitnet/Dockerfile" ]; then
                                    PROJECT_DIR="sis-kitnet"
                                fi

                                cd "$PROJECT_DIR"

                docker build -t $IMAGE_NAME:latest \
                             -t $IMAGE_NAME:$BUILD_NUMBER .
                '''
            }
        }

        stage('Deploy') {
            steps {
                sh '''
                docker network inspect rede-local >/dev/null 2>&1 || docker network create rede-local

                docker stop $IMAGE_NAME || true
                docker rm $IMAGE_NAME || true

                docker run -d -p 4200:80 \
                  --name $IMAGE_NAME \
                  --network rede-local \
                  $IMAGE_NAME:latest
                '''
            }
        }
    }

    post {
        success {
            echo "Deploy realizado com sucesso!"
        }
        failure {
            echo "Erro no pipeline."
        }
        always {
            cleanWs()
        }
    }
}
