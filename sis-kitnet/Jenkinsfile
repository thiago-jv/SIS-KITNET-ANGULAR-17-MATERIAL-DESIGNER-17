pipeline {
    agent any

    options {
        timestamps()
        buildDiscarder(logRotator(numToKeepStr: '10'))
    }

    environment {
        IMAGE_NAME = 'kitnet-frontend'
        PROJECT_DIR = '.'
        SONAR_QUBE_URL = 'http://localhost:9000'
        DSONAR_LOGIN = credentials('DSONAR_LOGIN_SIS_KITNET_FRONTEND')
    }

    stages {

        stage('Checkout') {
            steps {
                checkout scm
            }
        }

        stage('Prepare Project Path') {
            steps {
                script {
                    env.PROJECT_DIR = fileExists('sis-kitnet/package-lock.json') ? 'sis-kitnet' : '.'
                    echo "Diretorio do projeto: ${env.PROJECT_DIR}"
                }
            }
        }

        stage('Build Frontend (Node via Docker)') {
            steps {
                sh '''
                docker run --rm \
                  --user "$(id -u):$(id -g)" \
                                    -e HOME=/tmp \
                                    -e npm_config_cache=/tmp/.npm \
                  -v $PWD:/app \
                                    -w /app/$PROJECT_DIR \
                  node:18 \
                  sh -c "npm ci && npm run build -- --configuration production"
                '''
            }
        }

        stage('SonarQube Analysis') {
            steps {
                withSonarQubeEnv('SONAR_LOCAL') {
                    script {
                        def scannerHome = tool 'SONAR_SCANNER'
                        dir(env.PROJECT_DIR) {
                            sh """
                        ${scannerHome}/bin/sonar-scanner \\
                        -Dsonar.projectKey=SIS_KITNET_FRONTEND \\
                        -Dsonar.projectName=SIS_KITNET_FRONTEND \\
                        -Dsonar.host.url=${env.SONAR_QUBE_URL} \\
                        -Dsonar.token=${env.DSONAR_LOGIN} \\
                        -Dsonar.sources=src \\
                        -Dsonar.tests=src \\
                        -Dsonar.test.inclusions=**/*.spec.ts \\
                        -Dsonar.exclusions=**/node_modules/**,**/*.spec.ts,**/dist/** \\
                        -Dsonar.typescript.tsconfigPath=tsconfig.json
                        """
                        }
                    }
                }
            }
        }

        stage('Quality Gate') {
            steps {
                timeout(time: 10, unit: 'MINUTES') {
                    waitForQualityGate abortPipeline: true
                }
            }
        }

        stage('Docker Build') {
            steps {
                dir(env.PROJECT_DIR) {
                    sh '''
                    docker build -t $IMAGE_NAME:latest \
                                 -t $IMAGE_NAME:$BUILD_NUMBER .
                    '''
                }
            }
        }

        stage('Deploy') {
            steps {
                sh '''
                docker network inspect rede-local >/dev/null 2>&1 || docker network create rede-local

                docker stop $IMAGE_NAME || true
                docker rm $IMAGE_NAME || true

                docker run -d -p 4200:80 \
                  --name $IMAGE_NAME \
                  --network rede-local \
                  $IMAGE_NAME:latest
                '''
            }
        }
    }

    post {
        success {
            echo "Pipeline concluido com sucesso. Build ${BUILD_NUMBER}."
        }
        failure {
            echo "Pipeline falhou. Verifique os logs das stages."
        }
        always {
            cleanWs()
        }
    }
}
