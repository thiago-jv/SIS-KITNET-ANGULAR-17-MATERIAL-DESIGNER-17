<?xml version="1.0" encoding="UTF-8"?>
<jasperReport xmlns="http://jasperreports.sourceforge.net/jasperreports"
 xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
 xsi:schemaLocation="http://jasperreports.sourceforge.net/jasperreports
 http://jasperreports.sourceforge.net/xsd/jasperreport.xsd"
 name="recibo_kitnet"
 pageWidth="595"
 pageHeight="842"
 columnWidth="555"
 leftMargin="20"
 rightMargin="20"
 topMargin="20"
 bottomMargin="20">

    <field name="dataEntrada" class="java.lang.String"/>
    <field name="nomeInquilino" class="java.lang.String"/>
    <field name="valor" class="java.lang.String"/>
    <field name="predio" class="java.lang.String"/>
    <field name="numeroQuarto" class="java.lang.String"/>
    <field name="cep" class="java.lang.String"/>
    <field name="bairro" class="java.lang.String"/>
    <field name="uf" class="java.lang.String"/>
    <field name="localidade" class="java.lang.String"/>
    <field name="logradouro" class="java.lang.String"/>
    <field name="idLancamento" class="java.lang.Long"/>

    <title>
        <band height="200">

            <!-- Título -->
            <staticText>
                <reportElement x="0" y="0" width="555" height="40"/>
                <textElement textAlignment="Center">
                    <font size="24" isBold="true"/>
                </textElement>
                <text><![CDATA[RECIBO DE PAGAMENTO]]></text>
            </staticText>

            <!-- Recibo numero -->
            <staticText>
                <reportElement x="0" y="50" width="100" height="20"/>
                <text><![CDATA[Recibo Nº:]]></text>
            </staticText>

            <textField>
                <reportElement x="80" y="50" width="80" height="20"/>
                <textFieldExpression><![CDATA[$F{idLancamento}]]></textFieldExpression>
            </textField>

            <!-- Data -->
            <staticText>
                <reportElement x="350" y="50" width="50" height="20"/>
                <text><![CDATA[Data:]]></text>
            </staticText>

            <textField pattern="dd/MM/yyyy">
                <reportElement x="400" y="50" width="120" height="20"/>
                <textFieldExpression><![CDATA[new java.util.Date()]]></textFieldExpression>
            </textField>

            <!-- Valor destacado -->
            <frame>
                <reportElement x="380" y="80" width="160" height="70"
                               backcolor="#F2F4F4" mode="Opaque"/>

                <staticText>
                    <reportElement x="0" y="5" width="160" height="20"/>
                    <textElement textAlignment="Center">
                        <font size="10" isBold="true"/>
                    </textElement>
                    <text><![CDATA[VALOR RECEBIDO]]></text>
                </staticText>

                <textField>
                    <reportElement x="0" y="25" width="160" height="35"/>
                    <textElement textAlignment="Center">
                        <font size="20" isBold="true"/>
                    </textElement>
                    <textFieldExpression><![CDATA[$F{valor}]]></textFieldExpression>
                </textField>

            </frame>

        </band>
    </title>

    <columnHeader>
        <band height="420">

            <!-- Recebi -->
            <staticText>
                <reportElement x="0" y="20" width="120" height="20"/>
                <text><![CDATA[Recebi(emos) de:]]></text>
            </staticText>

            <textField>
                <reportElement x="120" y="20" width="350" height="20"/>
                <textFieldExpression><![CDATA[$F{nomeInquilino}]]></textFieldExpression>
            </textField>

            <!-- Quantia -->
            <staticText>
                <reportElement x="0" y="60" width="120" height="20"/>
                <text><![CDATA[A quantia de:]]></text>
            </staticText>

            <textField>
                <reportElement x="120" y="60" width="200" height="20"/>
                <textFieldExpression><![CDATA[$F{valor}]]></textFieldExpression>
            </textField>

            <!-- Referente -->
            <staticText>
                <reportElement x="0" y="100" width="120" height="20"/>
                <text><![CDATA[Referente a:]]></text>
            </staticText>

            <textField>
                <reportElement x="120" y="100" width="400" height="20"/>
                <textFieldExpression><![CDATA[
"Pagamento do aluguel do Kitnet nº "
+ $F{predio}
+ " - Quarto "
+ $F{numeroQuarto}
]]></textFieldExpression>
            </textField>

            <!-- Linha separadora -->
            <line>
                <reportElement x="0" y="140" width="555" height="1"/>
            </line>

            <!-- Endereço -->
            <staticText>
                <reportElement x="0" y="160" width="200" height="20"/>
                <textElement>
                    <font isBold="true"/>
                </textElement>
                <text><![CDATA[Endereço]]></text>
            </staticText>

            <textField>
                <reportElement x="0" y="190" width="400" height="20"/>
                <textFieldExpression><![CDATA[$F{logradouro}]]></textFieldExpression>
            </textField>

            <textField>
                <reportElement x="0" y="210" width="400" height="20"/>
                <textFieldExpression><![CDATA[$F{bairro}]]></textFieldExpression>
            </textField>

            <textField>
                <reportElement x="0" y="230" width="200" height="20"/>
                <textFieldExpression><![CDATA["CEP: " + $F{cep}]]></textFieldExpression>
            </textField>

            <textField>
                <reportElement x="0" y="250" width="200" height="20"/>
                <textFieldExpression><![CDATA[$F{localidade} + " - " + $F{uf}]]></textFieldExpression>
            </textField>

            <!-- Local e data -->
            <textField pattern="dd 'de' MMMM 'de' yyyy">
                <reportElement x="0" y="300" width="300" height="20"/>
                <textFieldExpression><![CDATA[new java.util.Date()]]></textFieldExpression>
            </textField>

            <staticText>
                <reportElement x="0" y="280" width="200" height="20"/>
                <text><![CDATA[Manaus - AM]]></text>
            </staticText>

            <!-- Assinatura -->
            <line>
                <reportElement x="320" y="340" width="200" height="1"/>
            </line>

            <staticText>
                <reportElement x="320" y="345" width="200" height="20"/>
                <textElement textAlignment="Center"/>
                <text><![CDATA[Assinatura do Responsável]]></text>
            </staticText>

        </band>
    </columnHeader>

</jasperReport>