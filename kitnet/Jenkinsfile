def dockerapp

pipeline {
    agent any

    environment {
        K8S_NAMESPACE = 'default'
        K8S_DEPLOYMENT = 'sis-kitnet-backend'
        K8S_CONTAINER = 'sis-kitnet-backend'
        KUBECONFIG_CREDENTIALS_ID = 'kubeconfig'
        DOCKERHUB_REPO = 'docjv/sis_kitnet_backend'
        DOCKERHUB_CREDENTIALS_ID = 'dockerhub'
        JWT_SECRET = credentials('JWT_SECRET')
        SPRING_DATASOURCE_USERNAME = credentials('DB_USERNAME_SIS_KITNET_BACKEND_API_PROD')
        SPRING_DATASOURCE_PASSWORD = credentials('DB_PASSWORD_SIS_KITNET_BACKEND_API_PROD')
        SONAR_QUBE_URL = 'http://localhost:9000'
        DSONAR_LOGIN = credentials('DSONAR_LOGIN')
    }

    stages {

        stage('Checkout') {
            steps {
                checkout scm
            }
        }

        stage('Build') {
            steps {
                dir('kitnet') {
                    sh 'chmod +x ./mvnw && ./mvnw clean package -DskipTests'
                }
            }
        }

        stage('SonarQube Analysis') {
            steps {
                withSonarQubeEnv('SONAR_LOCAL') {
                    dir('kitnet') {
                        sh """
                        ${tool 'SONAR_SCANNER'}/bin/sonar-scanner \\
                        -Dsonar.projectKey=SIS_KITNET_BACKEND \\
                        -Dsonar.host.url=${env.SONAR_QUBE_URL} \\
                        -Dsonar.login=${env.DSONAR_LOGIN} \\
                        -Dsonar.java.binaries=target/classes
                        """
                    }
                }
            }
        }

        stage('Quality Gate') {
            steps {
                sleep(10)
                timeout(time: 3, unit: 'MINUTES') {
                    waitForQualityGate abortPipeline: true
                }
            }
        }

        stage('Build Docker Image') {
            steps {
                dir('kitnet') {
                    script {
                        dockerapp = docker.build("${env.DOCKERHUB_REPO}:${env.BUILD_ID}", "-f Dockerfile .")
                    }
                }
            }
        }

        stage('Push Docker Image') {
            steps {
                script {
                    docker.withRegistry('https://registry.hub.docker.com', env.DOCKERHUB_CREDENTIALS_ID) {
                        dockerapp.push("${env.BUILD_ID}")
                        dockerapp.push('latest')
                    }
                }
            }
        }

        stage('Deploy Kubernetes') {
            steps {
                                // Carrega o kubeconfig salvo como credencial (arquivo) no Jenkins.
                                // Isso evita depender do ~/.kube/config da maquina do agente.
                withCredentials([file(credentialsId: env.KUBECONFIG_CREDENTIALS_ID, variable: 'KUBECONFIG_FILE')]) {
                                        // Garante que os comandos rodem na pasta do projeto onde estao os manifests.
                    dir('kitnet') {
                        sh '''
                                                        # Copia o kubeconfig para um arquivo temporario editavel em /tmp.
                                                        # Em alguns ambientes k3d, o server vem como 0.0.0.0, o que quebra o kubectl no Jenkins.
                            KUBECONFIG_TMP=$(mktemp /tmp/kubeconfig-jenkins-XXXXXX.yaml)
                            cp "$KUBECONFIG_FILE" "$KUBECONFIG_TMP"

                            # Se Jenkins roda em Docker, 127.0.0.1 aponta para o proprio container.
                            # Tenta detectar o IP do host via gateway da rede Docker (172.17.0.1 por padrao).
                            HOST_GW=$(ip route show default 2>/dev/null | awk '/default/ {print $3; exit}')
                            if [ -n "$HOST_GW" ]; then
                                echo "Gateway detectado: $HOST_GW — substituindo 0.0.0.0/127.0.0.1 pelo IP do host."
                                sed -i "s#https://0.0.0.0:#https://$HOST_GW:#g" "$KUBECONFIG_TMP"
                                sed -i "s#https://127.0.0.1:#https://$HOST_GW:#g" "$KUBECONFIG_TMP"
                            else
                                sed -i 's#https://0.0.0.0:#https://127.0.0.1:#g' "$KUBECONFIG_TMP"
                            fi

                            export KUBECONFIG="$KUBECONFIG_TMP"
                            trap "rm -f $KUBECONFIG_TMP" EXIT

                            # Validacoes rapidas de ambiente para facilitar troubleshooting.
                            kubectl version --client
                            kubectl config current-context

                            # Aguarda o API server ficar disponivel (ate 60s).
                            echo "Verificando conectividade com o API server..."
                            for i in $(seq 1 12); do
                                if kubectl cluster-info --request-timeout=5s > /dev/null 2>&1; then
                                    echo "API server disponivel."
                                    break
                                fi
                                echo "Tentativa $i/12 — API server indisponivel, aguardando 5s..."
                                sleep 5
                                if [ "$i" -eq 12 ]; then
                                    echo "API server nao respondeu apos 60s. Abortando."
                                    kubectl cluster-info || true
                                    exit 1
                                fi
                            done

                                                        # Cria/atualiza o Secret com credenciais vindas do Jenkins.
                                                        # --dry-run=client -o yaml gera o YAML sem aplicar direto.
                                                        # O pipe para kubectl apply torna o comando idempotente (create ou update).
                            kubectl create secret generic sis-kitnet-backend-secret \
                              --from-literal=SPRING_DATASOURCE_USERNAME="$SPRING_DATASOURCE_USERNAME" \
                              --from-literal=SPRING_DATASOURCE_PASSWORD="$SPRING_DATASOURCE_PASSWORD" \
                              --from-literal=JWT_SECRET="$JWT_SECRET" \
                                                            --dry-run=client -o yaml -n $K8S_NAMESPACE | kubectl apply --validate=false -f -

                                                        # Aplica Deployment + Service definidos no manifesto.
                                                        kubectl apply --validate=false -f k8s/deployment.yaml -n $K8S_NAMESPACE

                                                        # Atualiza a imagem para a tag imutavel do build atual.
                                                        # Isso evita depender de latest para deploy.
                            kubectl set image deployment/$K8S_DEPLOYMENT \
                              $K8S_CONTAINER=$DOCKERHUB_REPO:$BUILD_ID \
                              -n $K8S_NAMESPACE

                                                                                                                # Aguarda rollout terminar. Se falhar por timeout,
                                                                                                                # coleta diagnostico detalhado para troubleshooting.
                                                        set +e
                                                        kubectl rollout status deployment/$K8S_DEPLOYMENT -n $K8S_NAMESPACE --timeout=420s
                                                        ROLLOUT_EXIT_CODE=$?
                                                        set -e

                                                        if [ $ROLLOUT_EXIT_CODE -ne 0 ]; then
                                                            echo "Rollout nao concluiu no tempo limite. Coletando diagnostico..."
                                                            kubectl get deployment $K8S_DEPLOYMENT -n $K8S_NAMESPACE -o wide || true
                                                            kubectl describe deployment $K8S_DEPLOYMENT -n $K8S_NAMESPACE || true
                                                            kubectl get rs -n $K8S_NAMESPACE -l app=sis-kitnet-backend -o wide || true
                                                            kubectl get pods -n $K8S_NAMESPACE -l app=sis-kitnet-backend -o wide || true
                                                            kubectl describe pods -n $K8S_NAMESPACE -l app=sis-kitnet-backend || true

                                                            for pod in $(kubectl get pods -n $K8S_NAMESPACE -l app=sis-kitnet-backend -o name); do
                                                                echo "=== Logs de $pod (ultimas 150 linhas) ==="
                                                                kubectl logs -n $K8S_NAMESPACE "$pod" --tail=150 --all-containers=true || true
                                                            done

                                                            exit $ROLLOUT_EXIT_CODE
                                                        fi

                            kubectl get pods -n $K8S_NAMESPACE -l app=sis-kitnet-backend -o wide
                            kubectl get svc -n $K8S_NAMESPACE sis-kitnet-backend
                        '''
                    }
                }
            }
        }

        stage('Health Check Post-Deploy') {
            steps {
                withCredentials([file(credentialsId: env.KUBECONFIG_CREDENTIALS_ID, variable: 'KUBECONFIG_FILE')]) {
                    dir('kitnet') {
                        sh '''
                            KUBECONFIG_TMP=$(mktemp /tmp/kubeconfig-jenkins-XXXXXX.yaml)
                            cp "$KUBECONFIG_FILE" "$KUBECONFIG_TMP"
                            sed -i 's#https://0.0.0.0:#https://127.0.0.1:#g' "$KUBECONFIG_TMP"
                            export KUBECONFIG="$KUBECONFIG_TMP"
                            trap "rm -f $KUBECONFIG_TMP" EXIT
                            
                            # Aguarda 10 segundos para a aplicacao iniciar
                            echo "Aguardando aplicacao iniciar..."
                            sleep 10
                            
                            # Testa /actuator/health diretamente no cluster
                            echo "Verificando saude da aplicacao..."
                            kubectl run curltest-${BUILD_NUMBER} \
                              --image=curlimages/curl:latest \
                              --restart=Never \
                              -n $K8S_NAMESPACE \
                              -- curl -f http://${K8S_DEPLOYMENT}:8089/actuator/health || true
                            
                            # Aguarda a conclusao e limpa o pod de teste
                            sleep 5
                            kubectl delete pod curltest-${BUILD_NUMBER} -n $K8S_NAMESPACE --ignore-not-found=true
                        '''
                    }
                }
            }
        }
    }

    post {
        success {
            script {
                echo "Pipeline executado com sucesso! Build ${BUILD_NUMBER}."
            }
        }
        failure {
            script {
                echo "Pipeline falhou! Verifique os logs das stages."
            }
        }
        always {
            echo "Pipeline finalizada em \$(date)."
        }
    }
}