def dockerapp

pipeline {
    agent any

    environment {
        CONTAINER_NAME = 'kitnet-backend'
        DOCKERHUB_REPO = 'docjv/sis_kitnet_backend'
        DOCKERHUB_CREDENTIALS_ID = 'dockerhub'
        JWT_SECRET = credentials('JWT_SECRET')
        SPRING_DATASOURCE_USERNAME = credentials('DB_USERNAME_SIS_KITNET_BACKEND_API_PROD')
        SPRING_DATASOURCE_PASSWORD = credentials('DB_PASSWORD_SIS_KITNET_BACKEND_API_PROD')
        SONAR_QUBE_URL = 'http://localhost:9000'
        DSONAR_LOGIN = credentials('DSONAR_LOGIN')
    }

    stages {

        stage('Checkout') {
            steps {
                checkout scm
            }
        }

        stage('Build') {
            steps {
                dir('kitnet') {
                    sh 'chmod +x ./mvnw && ./mvnw clean package -DskipTests'
                }
            }
        }

        stage('SonarQube Analysis') {
            steps {
                withSonarQubeEnv('SONAR_LOCAL') {
                    dir('kitnet') {
                        sh """
                        ${tool 'SONAR_SCANNER'}/bin/sonar-scanner \\
                        -Dsonar.projectKey=SIS_KITNET_BACKEND \\
                        -Dsonar.host.url=${env.SONAR_QUBE_URL} \\
                        -Dsonar.login=${env.DSONAR_LOGIN} \\
                        -Dsonar.java.binaries=target/classes
                        """
                    }
                }
            }
        }

        stage('Quality Gate') {
            steps {
                sleep(10)
                timeout(time: 3, unit: 'MINUTES') {
                    waitForQualityGate abortPipeline: true
                }
            }
        }

        stage('Build Docker Image') {
            steps {
                dir('kitnet') {
                    script {
                        dockerapp = docker.build("${env.DOCKERHUB_REPO}:${env.BUILD_ID}", "-f Dockerfile .")
                    }
                }
            }
        }

        stage('Push Docker Image') {
            steps {
                script {
                    docker.withRegistry('https://registry.hub.docker.com', env.DOCKERHUB_CREDENTIALS_ID) {
                        dockerapp.push('latest')
                        dockerapp.push("${env.BUILD_ID}")
                    }
                }
            }
        }


        stage('Deploy') {
            steps {
                sh '''
                    # Garante que a rede existe
                    docker network inspect rede-local >/dev/null 2>&1 || docker network create rede-local

                    # Para e remove container antigo
                    docker stop $CONTAINER_NAME || true
                    docker rm $CONTAINER_NAME || true

                    # Garante a imagem mais recente do Docker Hub
                    docker pull $DOCKERHUB_REPO:latest

                    # Sobe novo container
                    docker run -d -p 8090:8089 \
                      --name $CONTAINER_NAME \
                      --network rede-local \
                      -e SPRING_PROFILES_ACTIVE=prod \
                      -e SPRING_DATASOURCE_USERNAME="$SPRING_DATASOURCE_USERNAME" \
                      -e SPRING_DATASOURCE_PASSWORD="$SPRING_DATASOURCE_PASSWORD" \
                      -e JWT_SECRET="${JWT_SECRET}" \
                      $DOCKERHUB_REPO:latest
                '''
            }
        }
    }

    post {
        success {
            echo "Pipeline executado com sucesso! Build ${BUILD_NUMBER}."
        }
        failure {
            echo "Pipeline falhou! Verifique os logs das stages."
        }
        always {
            echo "Pipeline finalizada."
        }
    }
}