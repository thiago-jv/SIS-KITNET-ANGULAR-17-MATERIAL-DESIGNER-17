def dockerapp

pipeline {
    agent any

    environment {
        K8S_NAMESPACE = 'default'
        K8S_DEPLOYMENT = 'sis-kitnet-backend'
        K8S_CONTAINER = 'sis-kitnet-backend'
        K8S_DB_HOSTNAME = 'db.kitnet.internal'
        K8S_DB_PORT = '5432'
        KUBECONFIG_CREDENTIALS_ID = 'kubeconfig'
        DOCKERHUB_REPO = 'docjv/sis_kitnet_backend'
        DOCKERHUB_CREDENTIALS_ID = 'dockerhub'
        JWT_SECRET = credentials('JWT_SECRET')
        SPRING_DATASOURCE_USERNAME = credentials('DB_USERNAME_SIS_KITNET_BACKEND_API_PROD')
        SPRING_DATASOURCE_PASSWORD = credentials('DB_PASSWORD_SIS_KITNET_BACKEND_API_PROD')
        SONAR_QUBE_URL = 'http://localhost:9000'
        DSONAR_LOGIN = credentials('DSONAR_LOGIN')
    }

    stages {

        stage('Checkout') {
            steps {
                checkout scm
            }
        }

        stage('Build') {
            steps {
                dir('kitnet') {
                    sh 'chmod +x ./mvnw && ./mvnw clean package -DskipTests'
                }
            }
        }

        stage('SonarQube Analysis') {
            steps {
                withSonarQubeEnv('SONAR_LOCAL') {
                    dir('kitnet') {
                        sh """
                        ${tool 'SONAR_SCANNER'}/bin/sonar-scanner \\
                        -Dsonar.projectKey=SIS_KITNET_BACKEND \\
                        -Dsonar.host.url=${env.SONAR_QUBE_URL} \\
                        -Dsonar.login=${env.DSONAR_LOGIN} \\
                        -Dsonar.java.binaries=target/classes
                        """
                    }
                }
            }
        }

        stage('Quality Gate') {
            steps {
                sleep(10)
                timeout(time: 3, unit: 'MINUTES') {
                    waitForQualityGate abortPipeline: true
                }
            }
        }

        stage('Build Docker Image') {
            steps {
                dir('kitnet') {
                    script {
                        dockerapp = docker.build("${env.DOCKERHUB_REPO}:${env.BUILD_ID}", "-f Dockerfile .")
                    }
                }
            }
        }

        stage('Push Docker Image') {
            steps {
                script {
                    docker.withRegistry('https://registry.hub.docker.com', env.DOCKERHUB_CREDENTIALS_ID) {
                        dockerapp.push("${env.BUILD_ID}")
                        dockerapp.push('latest')
                    }
                }
            }
        }

        stage('Deploy Kubernetes') {
            steps {
                withCredentials([file(credentialsId: env.KUBECONFIG_CREDENTIALS_ID, variable: 'KUBECONFIG_FILE')]) {
                    dir('kitnet') {
                        sh '''
                            set -e

                            KUBECONFIG_TMP=$(mktemp /tmp/kubeconfig-jenkins-XXXXXX.yaml)
                            cp "$KUBECONFIG_FILE" "$KUBECONFIG_TMP"
                            export KUBECONFIG="$KUBECONFIG_TMP"
                            trap "rm -f $KUBECONFIG_TMP" EXIT

                            echo "=== Preflight Kubernetes ==="
                            kubectl config current-context || true
                            API_SERVER=$(kubectl config view --minify -o jsonpath='{.clusters[0].cluster.server}' 2>/dev/null || true)
                            echo "API server do kubeconfig: $API_SERVER"
                            if ! kubectl version --request-timeout=10s >/dev/null 2>&1; then
                                echo "Falha de conectividade com o cluster Kubernetes."
                                echo "Valide o kubeconfig no Jenkins (credencial: $KUBECONFIG_CREDENTIALS_ID)."
                                echo "Endpoint atual no kubeconfig: $API_SERVER"
                                echo "Dica: se vier 127.0.0.1/localhost, o Jenkins precisa estar no mesmo host do cluster."
                                exit 1
                            fi
                            kubectl get ns --request-timeout=10s >/dev/null

                            DB_HOSTNAME="$K8S_DB_HOSTNAME"
                            DB_PORT="$K8S_DB_PORT"
                            SPRING_DATASOURCE_URL_VALUE="jdbc:postgresql://$DB_HOSTNAME:$DB_PORT/kitnet"

                            K3D_NETWORK=$(docker network ls --format '{{.Name}}' | grep '^k3d-' | head -n1)
                            K3D_GATEWAY=''
                            if [ -n "$K3D_NETWORK" ]; then
                                K3D_GATEWAY=$(docker network inspect "$K3D_NETWORK" -f '{{(index .IPAM.Config 0).Gateway}}' 2>/dev/null || true)
                            fi

                            kubectl create secret generic sis-kitnet-backend-secret \
                              --from-literal=SPRING_DATASOURCE_URL="$SPRING_DATASOURCE_URL_VALUE" \
                              --from-literal=SPRING_DATASOURCE_USERNAME="$SPRING_DATASOURCE_USERNAME" \
                              --from-literal=SPRING_DATASOURCE_PASSWORD="$SPRING_DATASOURCE_PASSWORD" \
                              --from-literal=JWT_SECRET="$JWT_SECRET" \
                              --dry-run=client -o yaml -n $K8S_NAMESPACE | kubectl apply -f -

                            kubectl apply -f k8s/deployment.yaml -n $K8S_NAMESPACE
                                                        if [ -n "$K3D_GATEWAY" ]; then
                                                                kubectl patch deployment/$K8S_DEPLOYMENT -n $K8S_NAMESPACE --type='merge' \
                                                                    -p "{\"spec\":{\"template\":{\"spec\":{\"hostAliases\":[{\"ip\":\"$K3D_GATEWAY\",\"hostnames\":[\"$DB_HOSTNAME\"]}]}}}}"
                                                        fi
                            kubectl set image deployment/$K8S_DEPLOYMENT \
                              $K8S_CONTAINER=$DOCKERHUB_REPO:$BUILD_ID \
                              -n $K8S_NAMESPACE
                            kubectl rollout status deployment/$K8S_DEPLOYMENT -n $K8S_NAMESPACE --timeout=300s

                            kubectl get pods -n $K8S_NAMESPACE -l app=sis-kitnet-backend -o wide
                            kubectl get svc -n $K8S_NAMESPACE sis-kitnet-backend
                        '''
                    }
                }
            }
        }
    }

    post {
        success {
            script {
                echo "Pipeline executado com sucesso! Build ${BUILD_NUMBER}."
            }
        }
        failure {
            script {
                echo "Pipeline falhou! Verifique os logs das stages."
            }
        }
        always {
            echo "Pipeline finalizada em \$(date)."
        }
    }
}