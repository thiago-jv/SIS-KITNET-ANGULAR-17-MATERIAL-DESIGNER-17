def dockerapp

pipeline {
    agent any

    environment {
        K8S_NAMESPACE = 'default'
        K8S_DEPLOYMENT = 'sis-kitnet-backend'
        K8S_DB_HOSTNAME = 'host.docker.internal'
        K8S_DB_PORT = '5432'
        K8S_API_SERVER_OVERRIDE = 'https://127.0.0.1:33321'
        KUBECONFIG_CREDENTIALS_ID = 'kubeconfig'
        DOCKERHUB_REPO = 'docjv/sis_kitnet_backend'
        DOCKERHUB_CREDENTIALS_ID = 'dockerhub'
        JWT_SECRET = credentials('JWT_SECRET')
        SPRING_DATASOURCE_USERNAME = credentials('DB_USERNAME_SIS_KITNET_BACKEND_API_PROD')
        SPRING_DATASOURCE_PASSWORD = credentials('DB_PASSWORD_SIS_KITNET_BACKEND_API_PROD')
        SONAR_QUBE_URL = 'http://localhost:9000'
        DSONAR_LOGIN = credentials('DSONAR_LOGIN')
    }

    stages {

        stage('Checkout') {
            steps {
                checkout scm
            }
        }

        stage('Build') {
            steps {
                dir('kitnet') {
                    sh 'chmod +x ./mvnw && ./mvnw clean package -DskipTests'
                }
            }
        }

        stage('SonarQube Analysis') {
            steps {
                withSonarQubeEnv('SONAR_LOCAL') {
                    dir('kitnet') {
                        sh """
                        ${tool 'SONAR_SCANNER'}/bin/sonar-scanner \\
                        -Dsonar.projectKey=SIS_KITNET_BACKEND \\
                        -Dsonar.host.url=${env.SONAR_QUBE_URL} \\
                        -Dsonar.login=${env.DSONAR_LOGIN} \\
                        -Dsonar.java.binaries=target/classes
                        """
                    }
                }
            }
        }

        stage('Quality Gate') {
            steps {
                sleep(10)
                timeout(time: 3, unit: 'MINUTES') {
                    waitForQualityGate abortPipeline: true
                }
            }
        }

        stage('Build Docker Image') {
            steps {
                dir('kitnet') {
                    script {
                        dockerapp = docker.build("${env.DOCKERHUB_REPO}:${env.BUILD_ID}", "-f Dockerfile .")
                    }
                }
            }
        }

        stage('Push Docker Image') {
            steps {
                script {
                    docker.withRegistry('https://registry.hub.docker.com', env.DOCKERHUB_CREDENTIALS_ID) {
                        dockerapp.push("${env.BUILD_ID}")
                        dockerapp.push('latest')
                    }
                }
            }
        }

        stage('Deploy Kubernetes') {
            steps {
                script {
                    def kubeConfigArgs = [credentialsId: env.KUBECONFIG_CREDENTIALS_ID]
                    if (env.K8S_API_SERVER_OVERRIDE?.trim()) {
                        kubeConfigArgs.serverUrl = env.K8S_API_SERVER_OVERRIDE
                    }
                    dir('kitnet/k8s') {
                        withEnv(["TAG_VERSION=${env.BUILD_ID}"]) {
                            withKubeConfig(kubeConfigArgs) {
                                sh '''
                                    set -e

                                    kubectl version --request-timeout=10s >/dev/null

                                                                        DB_HOSTNAME="$K8S_DB_HOSTNAME"
                                                                        KIND_GATEWAY=$(docker network inspect kind -f '{{range .IPAM.Config}}{{println .Gateway}}{{end}}' 2>/dev/null | grep -m1 -E '^[0-9.]+$' || true)
                                                                        if [ -n "$KIND_GATEWAY" ]; then
                                                                            DB_HOSTNAME="$KIND_GATEWAY"
                                                                        fi

                                    kubectl create secret generic sis-kitnet-backend-secret \
                                                                            --from-literal=SPRING_DATASOURCE_URL="jdbc:postgresql://$DB_HOSTNAME:$K8S_DB_PORT/kitnet" \
                                      --from-literal=SPRING_DATASOURCE_USERNAME="$SPRING_DATASOURCE_USERNAME" \
                                      --from-literal=SPRING_DATASOURCE_PASSWORD="$SPRING_DATASOURCE_PASSWORD" \
                                      --from-literal=JWT_SECRET="$JWT_SECRET" \
                                      --dry-run=client -o yaml -n "$K8S_NAMESPACE" | kubectl apply -f -

                                    cp deployment.yaml deployment.rendered.yaml
                                    sed -i "s|{{TAG}}|$TAG_VERSION|g" deployment.rendered.yaml
                                    kubectl apply -f service.yaml -f deployment.rendered.yaml -n "$K8S_NAMESPACE"
                                    kubectl rollout status deployment/"$K8S_DEPLOYMENT" -n "$K8S_NAMESPACE" --timeout=300s
                                '''
                            }
                        }
                    }
                }
            }
        }
    }

    post {
        success {
            script {
                echo "Pipeline executado com sucesso! Build ${BUILD_NUMBER}."
            }
        }
        failure {
            script {
                echo "Pipeline falhou! Verifique os logs das stages."
            }
        }
        always {
            echo "Pipeline finalizada em \$(date)."
        }
    }
}