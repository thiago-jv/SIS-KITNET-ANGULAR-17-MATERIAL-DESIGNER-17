def dockerapp

pipeline {
    agent any

    environment {
        K8S_NAMESPACE = 'default'
        K8S_DEPLOYMENT = 'sis-kitnet-backend'
        K8S_CONTAINER = 'sis-kitnet-backend'
        K8S_DB_HOSTNAME = 'db.kitnet.internal'
        K8S_DB_PORT = '5432'
        K8S_API_SERVER_OVERRIDE = ''
        KUBECONFIG_CREDENTIALS_ID = 'kubeconfig'
        DOCKERHUB_REPO = 'docjv/sis_kitnet_backend'
        DOCKERHUB_CREDENTIALS_ID = 'dockerhub'
        JWT_SECRET = credentials('JWT_SECRET')
        SPRING_DATASOURCE_USERNAME = credentials('DB_USERNAME_SIS_KITNET_BACKEND_API_PROD')
        SPRING_DATASOURCE_PASSWORD = credentials('DB_PASSWORD_SIS_KITNET_BACKEND_API_PROD')
        SONAR_QUBE_URL = 'http://localhost:9000'
        DSONAR_LOGIN = credentials('DSONAR_LOGIN')
    }

    stages {

        stage('Checkout') {
            steps {
                checkout scm
            }
        }

        stage('Build') {
            steps {
                dir('kitnet') {
                    sh 'chmod +x ./mvnw && ./mvnw clean package -DskipTests'
                }
            }
        }

        stage('SonarQube Analysis') {
            steps {
                withSonarQubeEnv('SONAR_LOCAL') {
                    dir('kitnet') {
                        sh """
                        ${tool 'SONAR_SCANNER'}/bin/sonar-scanner \\
                        -Dsonar.projectKey=SIS_KITNET_BACKEND \\
                        -Dsonar.host.url=${env.SONAR_QUBE_URL} \\
                        -Dsonar.login=${env.DSONAR_LOGIN} \\
                        -Dsonar.java.binaries=target/classes
                        """
                    }
                }
            }
        }

        stage('Quality Gate') {
            steps {
                sleep(10)
                timeout(time: 3, unit: 'MINUTES') {
                    waitForQualityGate abortPipeline: true
                }
            }
        }

        stage('Build Docker Image') {
            steps {
                dir('kitnet') {
                    script {
                        dockerapp = docker.build("${env.DOCKERHUB_REPO}:${env.BUILD_ID}", "-f Dockerfile .")
                    }
                }
            }
        }

        stage('Push Docker Image') {
            steps {
                script {
                    docker.withRegistry('https://registry.hub.docker.com', env.DOCKERHUB_CREDENTIALS_ID) {
                        dockerapp.push("${env.BUILD_ID}")
                        dockerapp.push('latest')
                    }
                }
            }
        }

        stage('Deploy Kubernetes') {
            steps {
                script {
                    def tag_version = env.BUILD_ID
                    dir('kitnet/k8s') {
                        withKubeConfig([credentialsId: env.KUBECONFIG_CREDENTIALS_ID]) {
                            sh "kubectl create secret generic sis-kitnet-backend-secret --from-literal=SPRING_DATASOURCE_URL=jdbc:postgresql://${env.K8S_DB_HOSTNAME}:${env.K8S_DB_PORT}/kitnet --from-literal=SPRING_DATASOURCE_USERNAME=${env.SPRING_DATASOURCE_USERNAME} --from-literal=SPRING_DATASOURCE_PASSWORD=${env.SPRING_DATASOURCE_PASSWORD} --from-literal=JWT_SECRET=${env.JWT_SECRET} --dry-run=client -o yaml -n ${env.K8S_NAMESPACE} | kubectl apply -f -"
                            sh "sed -i 's|{{TAG}}|${tag_version}|g' deployment.yaml"
                            sh "kubectl apply -f deployment.yaml -n ${env.K8S_NAMESPACE}"
                            sh "kubectl rollout status deployment/${env.K8S_DEPLOYMENT} -n ${env.K8S_NAMESPACE} --timeout=300s"
                        }
                    }
                }
            }
        }
    }

    post {
        success {
            script {
                echo "Pipeline executado com sucesso! Build ${BUILD_NUMBER}."
            }
        }
        failure {
            script {
                echo "Pipeline falhou! Verifique os logs das stages."
            }
        }
        always {
            echo "Pipeline finalizada em \$(date)."
        }
    }
}