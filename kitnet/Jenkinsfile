pipeline {
    agent any

    options {
        timestamps()
        buildDiscarder(logRotator(numToKeepStr: '10'))
    }

    environment {
        IMAGE_NAME = 'kitnet-backend'
        PROJECT_DIR = '.'
        JWT_SECRET = credentials('JWT_SECRET')
        SONAR_QUBE_URL = 'http://localhost:9000'
        DSONAR_LOGIN = credentials('DSONAR_LOGIN')
    }

    stages {

        stage('Checkout') {
            steps {
                checkout scm
            }
        }

        stage('Prepare Project Path') {
            steps {
                script {
                    if (fileExists('mvnw') && fileExists('pom.xml')) {
                        env.PROJECT_DIR = '.'
                    } else if (fileExists('kitnet/mvnw') && fileExists('kitnet/pom.xml')) {
                        env.PROJECT_DIR = 'kitnet'
                    } else {
                        error('Nao foi possivel localizar mvnw/pom.xml em . ou kitnet')
                    }
                    echo "Diretorio do projeto: ${env.PROJECT_DIR}"
                }
            }
        }

        stage('Build') {
            steps {
                dir(env.PROJECT_DIR) {
                                        sh '''
                                        if [ -f ./mvnw ]; then
                                            chmod +x ./mvnw
                                            ./mvnw clean package -DskipTests
                                        else
                                            mvn clean package -DskipTests
                                        fi
                                        '''
                }
            }
        }

        stage('SonarQube Analysis') {
            steps {
                withSonarQubeEnv('SONAR_LOCAL') {
                    script {
                        def scannerHome = tool 'SONAR_SCANNER'
                        dir(env.PROJECT_DIR) {
                            sh """
                            ${scannerHome}/bin/sonar-scanner \\
                            -Dsonar.projectKey=SIS_KITNET_BACKEND \\
                            -Dsonar.projectName=SIS_KITNET_BACKEND \\
                            -Dsonar.host.url=${env.SONAR_QUBE_URL} \\
                            -Dsonar.token=${env.DSONAR_LOGIN} \\
                            -Dsonar.sources=src/main/java,src/main/resources \\
                            -Dsonar.tests=src/test/java \\
                            -Dsonar.java.binaries=target/classes \\
                            -Dsonar.java.test.binaries=target/test-classes
                            """
                        }
                    }
                }
            }
        }

        stage('Quality Gate') {
            steps {
                timeout(time: 10, unit: 'MINUTES') {
                    waitForQualityGate abortPipeline: true
                }
            }
        }

        stage('Docker Build') {
            steps {
                dir(env.PROJECT_DIR) {
                    sh '''
                    docker build -t $IMAGE_NAME:latest \
                                 -t $IMAGE_NAME:$BUILD_NUMBER .
                    '''
                }
            }
        }

        stage('Deploy') {
            steps {
                sh '''
                    # Garante que a rede existe
                    docker network inspect rede-local >/dev/null 2>&1 || docker network create rede-local

                    # Para e remove container antigo
                    docker stop $IMAGE_NAME || true
                    docker rm $IMAGE_NAME || true

                    # Sobe novo container
                    docker run -d -p 8090:8089 \
                      --name $IMAGE_NAME \
                      --network rede-local \
                      -e JWT_SECRET="${JWT_SECRET}" \
                      $IMAGE_NAME:latest
                '''
            }
        }
    }

    post {
        success {
            echo "Pipeline concluido com sucesso. Build ${BUILD_NUMBER}."
        }
        failure {
            echo "Pipeline falhou. Verifique os logs das stages."
        }
        always {
            cleanWs()
        }
    }
}